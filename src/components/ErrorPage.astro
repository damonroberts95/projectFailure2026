---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	heading: string;
	message: string;
}

const { title, description, heading, message } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="chalkboard error-board">
		<span class="tag">Experiment failed</span>
		<h1>{heading}</h1>
		<p>{message}</p>
		<a class="marker-button" href="/">
			<span class="cap-band" aria-hidden="true"></span>
			Back to the lab
		</a>
	</div>
</BaseLayout>

<style>
	.error-board {
		text-align: center;
		max-width: 560px;
		margin: 3rem auto;
	}
	.error-board .tag {
		display: inline-block;
		font-family: var(--font-heading);
		background: var(--color-spark);
		color: var(--color-ink);
		padding: 0.2rem 0.7rem;
		border-radius: 3px;
		font-size: 0.85rem;
		margin-bottom: 0.75rem;
	}
	.error-board h1 {
		margin-top: 0;
	}
	.error-board p {
		margin: 0 0 1.5rem;
	}
</style>
