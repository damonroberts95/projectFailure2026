---
interface Props {
	title?: string;
}

const { title = 'Project Failure' } = Astro.props;
const pageURL = new URL(Astro.url.pathname, Astro.site).toString();

const links = [
	{
		name: 'X',
		className: 'x',
		href: `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageURL)}`,
		path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
	},
	{
		name: 'Facebook',
		className: 'facebook',
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageURL)}`,
		path: 'M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 1.859-.287 1.808h-3.246v7.981C18.209 23.238 23 18.062 23 11.75c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 6.312 4.791 11.489 10.101 12.941',
	},
	{
		name: 'WhatsApp',
		className: 'whatsapp',
		href: `https://wa.me/?text=${encodeURIComponent(`${title} ${pageURL}`)}`,
		path: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413',
	},
];
---

<div class="share-buttons">
	<span class="label">Share this</span>
	<div class="buttons">
		{
			links.map((link) => (
				<a
					class={`share-btn icon-btn ${link.className}`}
					href={link.href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Share on ${link.name}`}
				>
					<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path d={link.path} fill="currentColor" />
					</svg>
				</a>
			))
		}
		<button type="button" class="share-btn copy" data-copy-url={pageURL}>
			<svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
				<path
					d="M9 7h4a4 4 0 1 1 0 8h-2M15 17h-4a4 4 0 1 1 0-8h2"
					stroke="currentColor"
					stroke-width="2"
					fill="none"
					stroke-linecap="round"
				/>
			</svg>
			<span class="btn-label">Copy link</span>
		</button>
	</div>
</div>

<script>
	document.querySelectorAll<HTMLButtonElement>('button[data-copy-url]').forEach((button) => {
		const label = button.querySelector<HTMLSpanElement>('.btn-label');
		button.addEventListener('click', async () => {
			const url = button.dataset.copyUrl;
			if (!url || !label) return;
			await navigator.clipboard.writeText(url);
			const original = label.textContent;
			label.textContent = 'Copied!';
			setTimeout(() => {
				label.textContent = original;
			}, 1500);
		});
	});
</script>

<style>
	.share-buttons {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}
	.label {
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--color-ink);
	}
	.buttons {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}
	.share-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		border: none;
		border-radius: 999px;
		cursor: pointer;
		text-decoration: none !important;
		color: #fff;
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}
	.share-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
	}
	.icon-btn {
		width: 34px;
		height: 34px;
		justify-content: center;
	}
	.copy {
		padding: 0.4rem 0.9rem;
		font-size: 0.85rem;
		font-weight: 700;
		font-family: var(--font-body);
	}
	.share-btn.x {
		background: #15181c;
	}
	.share-btn.facebook {
		background: #1877f2;
	}
	.share-btn.whatsapp {
		/* white icon on brand green fails contrast (1.98:1) — dark icon instead */
		background: #25d366;
		color: var(--color-ink);
	}
	.share-btn.copy {
		background: var(--color-accent);
		color: var(--color-ink);
	}
</style>
