---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import { getCollection, render } from 'astro:content';
import { isPublished } from '../../lib/publish';

export async function getStaticPaths() {
	const sketches = await getCollection('sketches', ({ data }) => isPublished(data));
	return sketches.map((sketch) => ({
		params: { slug: sketch.id },
		props: { sketch },
	}));
}

const { sketch } = Astro.props;
const { Content } = await render(sketch);
const thumbnail = sketch.data.ogImage ?? `/images/generated/${sketch.id}.png`;
---

<BaseLayout
	title={sketch.data.title}
	description={sketch.data.description}
	image={thumbnail}
	type="article"
>
	<a class="back-link" href="/sketches/">&larr; Back to Sketches</a>
	<article class="card">
		<span class="tag">{sketch.data.genre}</span>
		<h1>{sketch.data.title}</h1>
		<p class="date">{sketch.data.pubDate.toDateString()}</p>

		{sketch.data.youtubeId && <YouTubeEmbed videoId={sketch.data.youtubeId} title={sketch.data.title} />}

		{!sketch.data.youtubeId && <img class="hero-image" src={thumbnail} alt="" />}

		{
			sketch.data.audioUrl && (
				<audio controls src={sketch.data.audioUrl}>
					Your browser does not support the audio element.
				</audio>
			)
		}

		<div class="prose">
			<Content />
		</div>

		{
			sketch.data.pdfFile && (
				<div class="script-block">
					<details class="script-expand">
						<summary>Read the script</summary>
						<iframe
							class="script-frame"
							data-src={sketch.data.pdfFile}
							title={`${sketch.data.title} script`}
							loading="lazy"
						/>
					</details>
					<a class="button" href={sketch.data.pdfFile}>
						Download the script (PDF)
					</a>
				</div>
			)
		}
	</article>
	<div class="share-wrap">
		<ShareButtons title={sketch.data.title} />
	</div>
</BaseLayout>

<style>
	.back-link {
		display: block;
		max-width: 680px;
		margin: 0 auto 1rem;
		font-weight: 600;
		font-size: 0.9rem;
	}
	.card {
		background: #fff;
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		padding: 1.5rem;
		max-width: 680px;
		margin: 0 auto;
	}
	.tag {
		display: inline-block;
		font-family: var(--font-heading);
		background: var(--color-spark);
		color: var(--color-ink);
		padding: 0.15rem 0.6rem;
		border-radius: 3px;
		font-size: 0.85rem;
	}
	.date {
		color: #666;
	}
	.hero-image {
		width: 100%;
		border-radius: calc(var(--radius-card) - 4px);
		display: block;
	}
	.prose {
		margin-top: 1rem;
	}
	.script-block {
		margin-top: 1.5rem;
	}
	.script-expand {
		margin-bottom: 0.75rem;
		border: 1px solid #ddd;
		border-radius: var(--radius-card);
		overflow: hidden;
	}
	.script-expand summary {
		cursor: pointer;
		padding: 0.75rem 1rem;
		font-weight: 700;
		background: var(--color-bg);
	}
	.script-expand[open] summary {
		border-bottom: 1px solid #ddd;
	}
	.script-frame {
		width: 100%;
		height: 70vh;
		border: none;
		display: block;
	}
	.share-wrap {
		max-width: 680px;
		margin: 1.5rem auto 0;
	}
</style>

<script>
	// default PDF viewer zoom: 80% on desktop (avoids the browser's default
	// full-page-fit view), fit-to-width on mobile where a fixed 80% would be
	// too small to read
	function setScriptFrameZoom() {
		document.querySelectorAll<HTMLIFrameElement>('.script-frame[data-src]').forEach((frame) => {
			const base = frame.dataset.src;
			if (!base) return;
			const isDesktop = window.matchMedia('(min-width: 768px)').matches;
			frame.src = isDesktop ? `${base}#zoom=80` : `${base}#view=FitH`;
		});
	}
	setScriptFrameZoom();
	document.addEventListener('astro:page-load', setScriptFrameZoom);
</script>
