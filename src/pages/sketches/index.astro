---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../../lib/publish';

const sketches = (await getCollection('sketches', ({ data }) => isPublished(data))).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Sketches" description="Comedy sketches about science, from Project Failure.">
	<h1>Sketches</h1>

	<ul class="screen-grid sketches-grid">
		{
			sketches.map((sketch) => (
				<li>
					<a class="screen-card" href={`/sketches/${sketch.id}/`}>
						<img src={sketch.data.ogImage ?? `/images/generated/${sketch.id}.png`} alt="" loading="lazy" />
						<div class="screen-card-body">
							<span class="genre">{sketch.data.genre}</span>
							<strong>{sketch.data.title}</strong>
							<p>{sketch.data.description}</p>
						</div>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>

<style>
	.sketches-grid {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
	}
	.screen-card-body p {
		margin: 0.35rem 0 0;
		color: #555;
		font-size: 0.9rem;
	}
</style>
