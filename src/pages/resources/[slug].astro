---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const resources = await getCollection('resources', ({ data }) => !data.draft);
	return resources.map((resource) => ({
		params: { slug: resource.id },
		props: { resource },
	}));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
---

<BaseLayout title={resource.data.title} description={resource.data.description} type="article">
	<article>
		<h1>{resource.data.title}</h1>
		<p>Audience: {resource.data.audience}</p>
		{resource.data.videoId && <YouTubeEmbed videoId={resource.data.videoId} title={resource.data.title} />}
		<Content />
		{resource.data.file && <p><a href={resource.data.file}>Download</a></p>}
	</article>
</BaseLayout>
