---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import { getCollection, render } from 'astro:content';
import { isPublished } from '../../lib/publish';

export async function getStaticPaths() {
	const resources = await getCollection('resources', ({ data }) => isPublished(data));
	return resources.map((resource) => ({
		params: { slug: resource.id },
		props: { resource },
	}));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
const thumbnail = resource.data.ogImage || `/images/generated/${resource.id}.png`;
const hasScript = resource.data.script || Boolean(resource.data.pdfFile);
const scriptPdf = resource.data.pdfFile || `/downloads/generated/${resource.id}.pdf`;
---

<BaseLayout
	title={resource.data.title}
	description={resource.data.description}
	image={thumbnail}
	type="article"
>
	<a class="back-link" href="/resources/">&larr; Back to Resources</a>
	<article class="card">
		<span class="tag">{resource.data.genre}</span>
		<h1>{resource.data.title}</h1>
		<p class="date">{resource.data.pubDate.toDateString()}</p>
		{resource.data.credits && <p class="credits">{resource.data.credits}</p>}

		{resource.data.youtubeId && <YouTubeEmbed videoId={resource.data.youtubeId} title={resource.data.title} />}

		{!resource.data.youtubeId && <img class="hero-image" src={thumbnail} alt="" />}

		{
			resource.data.audioUrl && (
				<audio controls src={resource.data.audioUrl}>
					Your browser does not support the audio element.
				</audio>
			)
		}

		<div class="prose">
			<Content />
		</div>

		{
			hasScript && (
				<div class="script-block">
					<details class="script-expand">
						<summary>Read the script</summary>
						<iframe class="script-frame" data-src={scriptPdf} title={`${resource.data.title} script`} loading="lazy" />
					</details>
					<a class="button" href={scriptPdf}>
						Download the script (PDF)
					</a>
				</div>
			)
		}
	</article>
	<div class="share-wrap">
		<ShareButtons title={resource.data.title} />
	</div>
</BaseLayout>

<style>
	.back-link {
		display: block;
		max-width: 680px;
		margin: 0 auto 1rem;
		font-weight: 600;
		font-size: 0.9rem;
	}
	.card {
		background: #fff;
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		padding: 1.5rem;
		max-width: 680px;
		margin: 0 auto;
	}
	.tag {
		display: inline-block;
		font-family: var(--font-heading);
		background: var(--color-spark);
		color: var(--color-ink);
		padding: 0.15rem 0.6rem;
		border-radius: 3px;
		font-size: 0.85rem;
	}
	.date {
		color: #666;
	}
	.credits {
		color: #666;
		font-size: 0.85rem;
		font-style: italic;
		margin-top: 0.15rem;
	}
	.hero-image {
		width: 100%;
		border-radius: calc(var(--radius-card) - 4px);
		display: block;
	}
	.prose {
		margin-top: 1rem;
	}
	.script-block {
		margin-top: 1.5rem;
	}
	.script-expand {
		margin-bottom: 0.75rem;
		border: 1px solid #ddd;
		border-radius: var(--radius-card);
		overflow: hidden;
	}
	.script-expand summary {
		cursor: pointer;
		padding: 0.75rem 1rem;
		font-weight: 700;
		background: var(--color-bg);
	}
	.script-expand[open] summary {
		border-bottom: 1px solid #ddd;
	}
	.script-frame {
		width: 100%;
		height: 70vh;
		border: none;
		display: block;
	}
	.share-wrap {
		max-width: 680px;
		margin: 1.5rem auto 0;
	}
</style>

<script>
	// default PDF viewer zoom: 80% on desktop (avoids the browser's default
	// full-page-fit view), fit-to-width on mobile where a fixed 80% would be
	// too small to read
	function setScriptFrameZoom() {
		document.querySelectorAll<HTMLIFrameElement>('.script-frame[data-src]').forEach((frame) => {
			const base = frame.dataset.src;
			if (!base) return;
			const isDesktop = window.matchMedia('(min-width: 768px)').matches;
			frame.src = isDesktop ? `${base}#zoom=80` : `${base}#view=FitH`;
		});
	}
	setScriptFrameZoom();
	document.addEventListener('astro:page-load', setScriptFrameZoom);
</script>
