---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../../lib/publish';

const resources = (await getCollection('resources', ({ data }) => isPublished(data))).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Resources" description="Comedy resources about science, from Project Failure.">
	<h1>Resources</h1>

	<ul class="screen-grid resources-grid">
		{
			resources.map((resource) => (
				<li>
					<a class="screen-card" href={`/resources/${resource.id}/`}>
						<img src={resource.data.ogImage || `/images/generated/${resource.id}.png`} alt="" loading="lazy" />
						<div class="screen-card-body">
							<span class="genre">{resource.data.genre}</span>
							<strong>{resource.data.title}</strong>
							<p>{resource.data.description}</p>
						</div>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>

<style>
	.resources-grid {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
	}
	.screen-card-body p {
		margin: 0.35rem 0 0;
		color: #555;
		font-size: 0.9rem;
	}
</style>
