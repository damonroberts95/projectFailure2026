---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const sketches = (await getCollection('sketches', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestSketch = sketches[0];
const latestPosts = posts.slice(0, 5);
---

<BaseLayout
	title="Home"
	description="Comedy sketches educating people about science, one bad experiment at a time."
>
	<h1>Project Failure</h1>
	<p>Comedy sketches educating people about science.</p>

	{
		latestSketch && (
			<section>
				<h2>Latest sketch</h2>
				<a href={`/sketches/${latestSketch.id}/`}>{latestSketch.data.title}</a>
			</section>
		)
	}

	<section>
		<h2>Latest posts</h2>
		<ul>
			{
				latestPosts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
