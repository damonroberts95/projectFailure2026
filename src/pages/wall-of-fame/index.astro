---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const SURVEY_URL = 'https://survey123.arcgis.com/share/796b4aba20994178b0a272d94f536577?portalUrl=https://ngexplore.maps.arcgis.com';

const submissions = (await getCollection('community', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Wall of Fame" description="Real science failures, shared by our community, that turned out fine in the end.">
	<div class="chalkboard">
		<h1>Wall of <del>Shame</del> <span class="fame">Fame</span></h1>
		<p>
			Every scientist has a story about the experiment that went sideways. Share yours and it might
			end up here.
		</p>
		<p><a class="button" href={SURVEY_URL} target="_blank" rel="noopener noreferrer">Share your story</a></p>

		<ul class="sticky-wall">
			{
				submissions.map((entry, i) => (
					<li class={`sticky-note tilt-${i % 4}`}>
						<a href={`/wall-of-fame/${entry.id}/`}>
							<strong>{entry.data.title}</strong>
							<p>{entry.data.description}</p>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</BaseLayout>

<style>
	.chalkboard {
		background: var(--color-board);
		background-image:
			radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.04), transparent 40%),
			radial-gradient(circle at 85% 75%, rgba(255, 255, 255, 0.03), transparent 45%);
		border: 10px solid var(--color-board-frame);
		border-radius: 6px;
		padding: 2rem;
		color: #f5f5f0;
	}
	.chalkboard h1 {
		color: #fff;
		letter-spacing: 1px;
		text-shadow:
			0 0 2px rgba(255, 255, 255, 0.5),
			1px 1px 0 rgba(255, 255, 255, 0.1);
	}
	del {
		text-decoration-color: var(--color-spark);
		text-decoration-thickness: 3px;
		opacity: 0.7;
	}
	.fame {
		display: inline-block;
		font-family: 'Caveat', cursive;
		color: var(--color-spark);
		transform: rotate(-5deg);
		font-size: 1.4em;
	}
	.sticky-wall {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	.sticky-note {
		background: var(--color-note);
		width: 220px;
		min-height: 160px;
		padding: 1rem;
		box-shadow: 3px 3px 8px rgba(0, 0, 0, 0.4);
	}
	.sticky-note a {
		color: #1a1a1a;
		text-decoration: none;
		display: block;
	}
	.tilt-0 {
		transform: rotate(-3deg);
	}
	.tilt-1 {
		transform: rotate(2deg);
	}
	.tilt-2 {
		transform: rotate(-1deg);
	}
	.tilt-3 {
		transform: rotate(3deg);
	}
	.sticky-note:hover {
		transform: rotate(0deg) scale(1.03);
	}
</style>
