---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const submissions = await getCollection('community', ({ data }) => !data.draft);
	return submissions.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
	<article>
		<h1>{entry.data.title}</h1>
		<p>{entry.data.pubDate.toDateString()}</p>
		<Content />
	</article>
	<ShareButtons title={entry.data.title} />
</BaseLayout>
