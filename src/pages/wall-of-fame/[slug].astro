---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';
import { noteColor, foldCorner, noteFont } from '../../lib/noteColor';
import { isPublished } from '../../lib/publish';

export async function getStaticPaths() {
	const submissions = await getCollection('community', ({ data }) => isPublished(data));
	return submissions.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
	<a class="back-link" href="/wall-of-fame/">&larr; Back to Wall of Fame</a>

	<article
		class={`sticky-note-big fold-${foldCorner(entry.id)}`}
		style={`--note-color: ${noteColor(entry.id)}; --note-font: ${noteFont(entry.id)}`}
		transition:name={`note-${entry.id}`}
	>
		<h1>{entry.data.title}</h1>
		<p class="date">{entry.data.pubDate.toDateString()}</p>
		<div class="prose">
			<Content />
		</div>
	</article>

	<div class="share-wrap">
		<ShareButtons title={entry.data.title} />
	</div>
</BaseLayout>

<style>
	.back-link {
		display: block;
		max-width: 560px;
		margin: 0 auto 1rem;
		font-weight: 600;
		font-size: 0.9rem;
	}
	.sticky-note-big {
		position: relative;
		max-width: 560px;
		margin: 0 auto;
		background: var(--note-color);
		background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.35), transparent 45%);
		padding: 2.5rem 2rem 2rem;
		box-shadow: 5px 6px 16px rgba(0, 0, 0, 0.4);
		transform: rotate(-1deg);
		color: var(--color-ink);
	}
	.sticky-note-big::after {
		content: '';
		position: absolute;
		width: 0;
		height: 0;
		border-style: solid;
		border-width: 0 0 26px 26px;
		border-color: transparent transparent rgba(0, 0, 0, 0.2) transparent;
	}
	.sticky-note-big.fold-br::after {
		bottom: 0;
		right: 0;
	}
	.sticky-note-big.fold-bl::after {
		bottom: 0;
		left: 0;
		transform: scaleX(-1);
	}
	.sticky-note-big.fold-tr::after {
		top: 0;
		right: 0;
		transform: scaleY(-1);
	}
	.sticky-note-big.fold-tl::after {
		top: 0;
		left: 0;
		transform: scale(-1, -1);
	}
	.sticky-note-big h1 {
		font-family: var(--note-font);
		font-size: 2.2rem;
		color: var(--color-ink);
	}
	.date {
		color: #555;
	}
	.prose {
		margin-top: 1rem;
	}
	.share-wrap {
		max-width: 560px;
		margin: 1.5rem auto 0;
	}
</style>
