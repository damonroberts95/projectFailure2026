---
import SEO from '../components/SEO.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
}

const { title, description, image, type } = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/sketches/', label: 'Sketches' },
	{ href: '/wall-of-fame/', label: 'Wall of Fame' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="alternate" type="application/rss+xml" title="Project Failure" href="/rss.xml" />
		<SEO title={title} description={description} image={image} type={type} />
	</head>
	<body>
		<header>
			<a class="brand" href="/">
				<img src="/favicon.svg" alt="" width="28" height="28" />
				Project Failure
			</a>
			<nav>
				{
					nav.map((item) => (
						<a href={item.href}>{item.label}</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; {new Date().getFullYear()} Project Failure.</p>
		</footer>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Permanent Marker';
		src: url('/fonts/permanent-marker.woff2') format('woff2');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'Caveat';
		src: url('/fonts/caveat-bold.woff2') format('woff2');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}

	:root {
		--color-bg: #faf6ea;
		--color-ink: #1a1a1a;
		--color-board: #1e3a2b;
		--color-board-frame: #6b4a30;
		--color-note: #fff6a8;
		--color-accent: #ffce45;
		--color-spark: #ff6b6b;
		--font-heading: 'Permanent Marker', cursive;
		--font-body: system-ui, sans-serif;
		/* shared "card" recipe for content containers (hero, CTAs, signposts) */
		--radius-card: 10px;
		--shadow-card: 0 4px 14px rgba(0, 0, 0, 0.12);
		/* flat "sticker" shadow, reserved for paper/tape accents (sticky notes, film labels) */
		--shadow-sticker: 3px 3px 0 rgba(26, 26, 26, 0.18);
	}

	html,
	body {
		height: 100%;
	}
	body {
		font-family: var(--font-body);
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		color: var(--color-ink);
		background-color: var(--color-bg);
		background-image:
			linear-gradient(rgba(30, 58, 43, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(30, 58, 43, 0.05) 1px, transparent 1px);
		background-size: 24px 24px;
	}

	h1 {
		font-family: var(--font-heading);
		color: var(--color-board);
	}
	h2,
	h3 {
		font-family: var(--font-body);
		font-weight: 800;
		letter-spacing: -0.01em;
		color: var(--color-board);
	}

	main a {
		color: var(--color-board);
		text-decoration-line: underline;
		text-decoration-style: solid;
		text-decoration-color: rgba(30, 58, 43, 0.35);
		text-underline-offset: 2px;
	}
	main a:hover {
		text-decoration-style: wavy;
		text-decoration-color: var(--color-spark);
	}

	header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 1.5rem;
		border-bottom: 3px dashed var(--color-board-frame);
		background: var(--color-bg);
	}
	header nav {
		display: flex;
		gap: 1rem;
	}
	header nav a {
		text-decoration: none;
		color: var(--color-ink);
		font-weight: 600;
	}
	header nav a:hover {
		color: var(--color-board);
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-heading);
		font-size: 1.3rem;
		font-weight: bold;
		text-decoration: none;
		color: var(--color-ink);
	}
	main {
		flex: 1 0 auto;
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		box-sizing: border-box;
	}
	footer {
		flex-shrink: 0;
		text-align: center;
		padding: 0.75rem;
		border-top: 1px dashed var(--color-board-frame);
		color: #999;
		font-size: 0.8rem;
	}
	footer p {
		margin: 0;
	}
	.button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-ink);
		padding: 0.7rem 1.4rem;
		border-radius: 999px;
		text-decoration: none !important;
		font-weight: bold;
		box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
		transition: transform 0.15s ease;
	}
	.button:hover {
		transform: translateY(-1px);
	}
</style>
