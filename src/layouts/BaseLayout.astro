---
import SEO from '../components/SEO.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
	footerShare?: boolean;
}

const { title, description, image, type, footerShare = false } = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/resources/', label: 'Resources' },
	{ href: '/wall-of-fame/', label: 'Wall of Fame' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="alternate" type="application/rss+xml" title="Project Failure" href="/rss.xml" />
		<SEO title={title} description={description} image={image} type={type} />
		<ClientRouter />
	</head>
	<body>
		<header>
			<a class="brand" href="/">
				<img src="/favicon.svg" alt="" width="28" height="28" />
				Project Failure
			</a>
			<nav>
				{
					nav.map((item) => (
						<a href={item.href}>{item.label}</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			{footerShare && <ShareButtons title="Project Failure" />}
			<p>
				&copy; {new Date().getFullYear()} Project Failure. <a href="mailto:hello@projectfailure.co.uk">hello@projectfailure.co.uk</a>
			</p>
			<p class="license-note">
				Content licensed under <a href="https://github.com/damonroberts95/projectFailure2026/blob/main/LICENSE">CC BY-NC-SA 4.0</a> — reuse with attribution, non-commercial, share-alike.
			</p>
		</footer>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Permanent Marker';
		src: url('/fonts/permanent-marker.woff2') format('woff2');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'Caveat';
		src: url('/fonts/caveat-bold.woff2') format('woff2');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'Kalam';
		src: url('/fonts/kalam-bold.woff2') format('woff2');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'Shadows Into Light';
		src: url('/fonts/shadows-into-light.woff2') format('woff2');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'Gochi Hand';
		src: url('/fonts/gochi-hand.woff2') format('woff2');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	:root {
		--color-bg: #faf6ea;
		--color-ink: #1a1a1a;
		--color-board: #1e3a2b;
		--color-board-frame: #6b4a30;
		--color-note: #fff6a8;
		--color-accent: #ffce45;
		--color-spark: #ff6b6b;
		--font-heading: 'Permanent Marker', cursive;
		--font-body: system-ui, sans-serif;
		/* shared "card" recipe for content containers (hero, CTAs, signposts) */
		--radius-card: 10px;
		--shadow-card: 0 4px 14px rgba(0, 0, 0, 0.12);
		/* flat "sticker" shadow, reserved for paper/tape accents (sticky notes, film labels) */
		--shadow-sticker: 3px 3px 0 rgba(26, 26, 26, 0.18);
	}

	html,
	body {
		height: 100%;
	}
	body {
		font-family: var(--font-body);
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		color: var(--color-ink);
		background-color: var(--color-bg);
		background-image:
			linear-gradient(rgba(30, 58, 43, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(30, 58, 43, 0.05) 1px, transparent 1px);
		background-size: 24px 24px;
	}

	h1 {
		font-family: var(--font-heading);
		color: var(--color-board);
	}
	h2,
	h3 {
		font-family: var(--font-body);
		font-weight: 800;
		letter-spacing: -0.01em;
		color: var(--color-board);
	}

	main a {
		color: var(--color-board);
		text-decoration-line: underline;
		text-decoration-style: solid;
		text-decoration-color: rgba(30, 58, 43, 0.35);
		text-underline-offset: 2px;
	}
	main a:hover {
		text-decoration-style: wavy;
		text-decoration-color: var(--color-spark);
	}

	header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 0.5rem 1rem;
		padding: 1rem 1.5rem;
		border-bottom: 3px dashed var(--color-board-frame);
		background: var(--color-bg);
	}
	header nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
	}
	header nav a {
		text-decoration: none;
		color: var(--color-ink);
		font-weight: 600;
	}
	header nav a:hover {
		color: var(--color-board);
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-heading);
		font-size: 1.3rem;
		font-weight: bold;
		text-decoration: none;
		color: var(--color-ink);
	}
	main {
		flex: 1 0 auto;
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		box-sizing: border-box;
	}
	footer {
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		text-align: center;
		padding: 1rem 1.5rem;
		background: var(--color-bg);
		border-top: 1px dashed var(--color-board-frame);
		color: #5a5a5a;
		font-size: 0.8rem;
	}
	footer .share-buttons {
		justify-content: center;
	}
	footer .label {
		font-size: 0.8rem;
		color: #5a5a5a;
	}
	footer p {
		margin: 0;
	}
	.license-note {
		font-size: 0.75rem;
	}
	.button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-ink);
		padding: 0.7rem 1.4rem;
		border-radius: 999px;
		text-decoration: none !important;
		font-weight: bold;
		box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
		transition: transform 0.15s ease;
	}
	.button:hover {
		transform: translateY(-1px);
	}
	.marker-button {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: var(--color-accent);
		color: var(--color-ink) !important;
		font-family: 'Caveat', cursive;
		font-weight: 700;
		font-size: 1.4rem;
		padding: 0.4rem 1.5rem 0.4rem 0.5rem;
		border-radius: 999px 999px 999px 6px;
		border: 3px solid var(--color-ink);
		text-decoration: none !important;
		transform: rotate(-2deg);
		box-shadow: var(--shadow-sticker);
		transition: transform 0.15s ease;
	}
	.marker-button:hover {
		transform: rotate(0deg) scale(1.04);
	}
	.marker-button .cap-band {
		width: 10px;
		height: 24px;
		background: var(--color-ink);
		border-radius: 3px;
		flex: none;
	}
	.chalkboard {
		background: var(--color-board);
		background-image:
			radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.04), transparent 40%),
			radial-gradient(circle at 85% 75%, rgba(255, 255, 255, 0.03), transparent 45%);
		border: 10px solid var(--color-board-frame);
		border-radius: 6px;
		padding: 2rem;
		color: #f5f5f0;
	}
	.chalkboard h1,
	.chalkboard h2 {
		color: #fff;
		letter-spacing: 1px;
		text-shadow:
			0 0 2px rgba(255, 255, 255, 0.5),
			1px 1px 0 rgba(255, 255, 255, 0.1);
	}

	/* shared "screening card" — ticket-stub thumbnail card, used by the homepage
	   Now Screening widget and the /resources/ list so both match */
	.screen-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1.25rem;
	}
	.screen-card {
		--punch-bg: var(--color-bg);
		position: relative;
		display: block;
		background: #fff;
		border-radius: var(--radius-card);
		overflow: hidden;
		color: var(--color-ink);
		text-decoration: none !important;
		box-shadow: var(--shadow-card);
		transition: transform 0.15s ease;
	}
	.screen-card:hover {
		transform: translateY(-3px);
	}
	.screen-card img {
		width: 100%;
		aspect-ratio: 16 / 9;
		max-height: 280px;
		display: block;
		object-fit: cover;
		background: var(--color-board);
	}
	/* ticket-stub tear line: dashed seam + two semicircle "punches", right where
	   the thumbnail meets the details — not just the card's vertical center */
	.screen-card-body {
		position: relative;
		padding: 0.75rem 0.9rem 0.9rem;
		border-top: 1px dashed rgba(0, 0, 0, 0.2);
	}
	.screen-card-body::before,
	.screen-card-body::after {
		content: '';
		position: absolute;
		top: 0;
		width: 14px;
		height: 14px;
		background: var(--punch-bg);
		border-radius: 50%;
		transform: translateY(-50%);
		z-index: 1;
	}
	.screen-card-body::before {
		left: -7px;
	}
	.screen-card-body::after {
		right: -7px;
	}
	.screen-card .genre {
		display: block;
		width: fit-content;
		font-family: var(--font-heading);
		line-height: 1.3;
		background: var(--color-spark);
		color: var(--color-ink);
		padding: 0.15rem 0.5rem;
		border-radius: 3px;
		font-size: 0.7rem;
		margin-bottom: 0.35rem;
	}
	.screen-card strong {
		display: block;
		font-size: 0.95rem;
	}
</style>
